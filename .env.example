# Inmobiliaria Mica — Backend env vars
# Copiar a .env y completar.

# DSN del Postgres de Easypanel Mica (project sytem_ia_pruebas)
# Formato: postgresql://USER:PASS@HOST:5432/DBNAME
PG_DSN=postgresql://postgres:CHANGE_ME@inmobiliaria-mica-postgres:5432/inmobiliaria_mica

# Secreto para firmar JWT (generar con: openssl rand -hex 32)
JWT_SECRET=replace-with-openssl-rand-hex-32-output

# Puerto (Easypanel mapea esto al dominio)
PORT=8000
